proxy_address    = "teleport.example.com"
user             = "engineer@example.com"
teleport_version = "18.0.0"
region           = "us-east-2"
env              = "dev"
team             = "platform"

# IAM role ARNs the AWS Console app is allowed to assume.
# Leave empty to skip AWS Console federation: console_role_arns = []
console_role_arns = [
  "arn:aws:iam::123456789012:role/ReadOnly",
  "arn:aws:iam::123456789012:role/PowerUser",
]
