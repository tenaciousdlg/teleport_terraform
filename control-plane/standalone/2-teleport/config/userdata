#!/bin/bash
set -euxo pipefail

# Verify AWS CLI is available
aws --version || { echo "AWS CLI missing"; exit 1; }

# Set hostname
sudo hostnamectl set-hostname ${proxy_address}

# Install auditd for Linux Audit System integration
# Teleport SSH service automatically writes to auditd when it detects it running
sudo dnf install -y audit
sudo systemctl enable auditd
sudo systemctl start auditd

# Create Teleport Enterprise license file (no-op if license is empty)
sudo mkdir -p /var/lib/teleport
cat <<EOF >/var/lib/teleport/license.pem
${license}
EOF

# Install Teleport
# To use agent managed updates on this node, replace the install command with:
#   curl https://cdn.teleport.dev/install-v${teleport_version}.sh | bash -s -- --updater
# See: https://goteleport.com/docs/upgrading/agent-managed-updates/
curl https://cdn.teleport.dev/install.sh | bash -s ${teleport_version} enterprise

# Write Teleport config
sudo tee /etc/teleport.yaml > /dev/null <<EOF
version: v3
teleport:
  nodename: ${proxy_address}
  data_dir: /var/lib/teleport
  log:
    output: /var/lib/teleport/teleport.log
    severity: INFO
    format:
      output: json
  ca_pin: ""

auth_service:
  enabled: "yes"
  listen_addr: 0.0.0.0:3025
  cluster_name: ${proxy_address}
  proxy_listener_mode: multiplex
  license_file: /var/lib/teleport/license.pem
  authentication:
    type: local
    second_factors: ["webauthn", "otp"]

proxy_service:
  enabled: "yes"
  web_listen_addr: 0.0.0.0:443
  public_addr: ${proxy_address}:443
  https_keypairs: []
  acme:
    enabled: yes
    email: ${user}

ssh_service:
  enabled: "yes"
  commands:
    - name: hostname
      command: [hostname]
      period: 1m0s
  labels:
    env: ${env}
    team: ${team}
    os: amazon-linux
  # Enhanced session recording (BPF/eBPF) — captures commands, args, and network
  # connections. Requires kernel 5.8+ (AL2023 ships 6.x — always supported).
  enhanced_recording:
    enabled: true
    command_buffer_size: 8
    disk_buffer_size: 128
    network_buffer_size: 8
EOF

sudo systemctl enable teleport.service
sudo systemctl restart teleport.service
sleep 10

# Write join token and initial admin user invite to S3
sudo tctl tokens add --type node,app,db,kube --format=text > /tmp/token
sudo tctl users add admin --roles=access,auditor,editor --logins=root,ec2-user > /tmp/user
aws s3 cp /tmp/token s3://${bucket}/token
aws s3 cp /tmp/user s3://${bucket}/user
