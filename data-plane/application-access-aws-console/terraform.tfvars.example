user             = "engineer@example.com"
proxy_address    = "teleport.example.com"
teleport_version = "18.6.4"
region           = "us-east-2"

# Your 12-digit AWS account ID
app_a_aws_account_id = "123456789012"

# Set to true to let Terraform create the default IAM roles
# (TeleportReadOnlyAccess, TeleportEC2Access, TeleportAdminAccess)
# in this account and wire them to the app host's instance profile.
# Set to false only if the roles already exist (e.g. managed separately).
manage_account_a_roles = true
